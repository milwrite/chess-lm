{
  "name": "chess-lm",
  "private": true,
  "version": "1.0.0",
  "description": "A Seventh Seal-inspired chess game with Stockfish Level 8 and an engine-grounded model council.",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=22.12.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "node server/index.mjs",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest run src && node --test server/*.test.mjs && npm run validate:model",
    "validate:model": "node scripts/validate-model-set.mjs"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "lucide-react": "^0.525.0",
    "react": "^19.2.7",
    "react-chessboard": "^5.10.0",
    "react-dom": "^19.2.7",
    "stockfish": "^18.0.8"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^3.2.4"
  }
}
